#!/bin/bash
set -e

# Challenge 5 Setup: Skills Assessment
echo "Setting up Challenge 5: Skills Assessment..."

# Clean workspace thoroughly
cd /root/terraform-lab
terraform destroy -auto-approve 2>/dev/null || true

# Clean all workspaces
for ws in $(terraform workspace list 2>/dev/null | grep -v "default" | tr -d '*' | xargs); do
    terraform workspace select default 2>/dev/null || true
    terraform workspace delete "$ws" 2>/dev/null || true
done

# Clean files
rm -rf *
rm -rf .terraform*
rm -rf terraform.tfstate*

# Create comprehensive solution in separate directory
mkdir -p /root/terraform-lab-solutions/challenge-05
cd /root/terraform-lab-solutions/challenge-05

# Create main.tf with complete infrastructure
cat > main.tf << 'EOF'
terraform {
  required_version = ">= 1.0"
  
  required_providers {
    libvirt = {
      source  = "dmacvicar/libvirt"
      version = "~> 0.9"
    }
  }
}

provider "libvirt" {
  uri = "qemu:///system"
}

# Base image
resource "libvirt_volume" "base" {
  name = "ubuntu-22.04-base.qcow2"
  pool = "default"
  
  source = "https://cloud-images.ubuntu.com/releases/22.04/release/ubuntu-22.04-server-cloudimg-amd64.img"
  
  target = {
    format = {
      type = "qcow2"
    }
  }
}

# Network
resource "libvirt_network" "app_network" {
  name      = "${var.environment}-network"
  autostart = true
}

# VM volumes
resource "libvirt_volume" "web_disk" {
  name = "${var.environment}-web-disk.qcow2"
  pool = "default"
  
  base_volume = libvirt_volume.base.id
  capacity    = var.vm_specs[var.environment].web.disk_size
  
  target = {
    format = {
      type = "qcow2"
    }
  }
}

resource "libvirt_volume" "app_disk" {
  name = "${var.environment}-app-disk.qcow2"
  pool = "default"
  
  base_volume = libvirt_volume.base.id
  capacity    = var.vm_specs[var.environment].app.disk_size
  
  target = {
    format = {
      type = "qcow2"
    }
  }
}

resource "libvirt_volume" "db_disk" {
  name = "${var.environment}-db-disk.qcow2"
  pool = "default"
  
  base_volume = libvirt_volume.base.id
  capacity    = var.vm_specs[var.environment].db.disk_size
  
  target = {
    format = {
      type = "qcow2"
    }
  }
}

# Cloud-init disks
resource "libvirt_cloudinit_disk" "web_init" {
  name      = "${var.environment}-web-init.iso"
  pool      = "default"
  user_data = templatefile("${path.module}/cloud-init-web.yaml", {
    hostname    = "${var.environment}-web"
    environment = var.environment
  })
  meta_data = yamlencode({
    instance-id    = "${var.environment}-web-server-01"
    local-hostname = "${var.environment}-web"
  })
}

resource "libvirt_cloudinit_disk" "app_init" {
  name      = "${var.environment}-app-init.iso"
  pool      = "default"
  user_data = templatefile("${path.module}/cloud-init-app.yaml", {
    hostname    = "${var.environment}-app"
    environment = var.environment
  })
  meta_data = yamlencode({
    instance-id    = "${var.environment}-app-server-01"
    local-hostname = "${var.environment}-app"
  })
}

resource "libvirt_cloudinit_disk" "db_init" {
  name      = "${var.environment}-db-init.iso"
  pool      = "default"
  user_data = templatefile("${path.module}/cloud-init-db.yaml", {
    hostname    = "${var.environment}-db"
    environment = var.environment
  })
  meta_data = yamlencode({
    instance-id    = "${var.environment}-db-server-01"
    local-hostname = "${var.environment}-db"
  })
}

# VMs
resource "libvirt_domain" "web" {
  name   = "${var.environment}-web"
  memory = var.vm_specs[var.environment].web.memory
  vcpu   = var.vm_specs[var.environment].web.vcpu
  type   = "kvm"
  
  os = {
    type         = "hvm"
    type_arch    = "x86_64"
    type_machine = "pc"
  }
  
  cloudinit = libvirt_cloudinit_disk.web_init.id
  
  devices = {
    disk = [{
      volume = {
        volume = libvirt_volume.web_disk.id
      }
      target = {
        dev = "vda"
        bus = "virtio"
      }
    }]
    
    interface = [{
      network = {
        network = libvirt_network.app_network.name
      }
      model = {
        type = "virtio"
      }
      wait_for_lease = true
    }]
  }
  
  console = {
    type = "pty"
    target = {
      type = "serial"
      port = 0
    }
  }
}

resource "libvirt_domain" "app" {
  name   = "${var.environment}-app"
  memory = var.vm_specs[var.environment].app.memory
  vcpu   = var.vm_specs[var.environment].app.vcpu
  type   = "kvm"
  
  os = {
    type         = "hvm"
    type_arch    = "x86_64"
    type_machine = "pc"
  }
  
  cloudinit = libvirt_cloudinit_disk.app_init.id
  
  devices = {
    disk = [{
      volume = {
        volume = libvirt_volume.app_disk.id
      }
      target = {
        dev = "vda"
        bus = "virtio"
      }
    }]
    
    interface = [{
      network = {
        network = libvirt_network.app_network.name
      }
      model = {
        type = "virtio"
      }
      wait_for_lease = true
    }]
  }
  
  console = {
    type = "pty"
    target = {
      type = "serial"
      port = 0
    }
  }
}

resource "libvirt_domain" "db" {
  name   = "${var.environment}-db"
  memory = var.vm_specs[var.environment].db.memory
  vcpu   = var.vm_specs[var.environment].db.vcpu
  type   = "kvm"
  
  os = {
    type         = "hvm"
    type_arch    = "x86_64"
    type_machine = "pc"
  }
  
  cloudinit = libvirt_cloudinit_disk.db_init.id
  
  devices = {
    disk = [{
      volume = {
        volume = libvirt_volume.db_disk.id
      }
      target = {
        dev = "vda"
        bus = "virtio"
      }
    }]
    
    interface = [{
      network = {
        network = libvirt_network.app_network.name
      }
      model = {
        type = "virtio"
      }
      wait_for_lease = true
    }]
  }
  
  console = {
    type = "pty"
    target = {
      type = "serial"
      port = 0
    }
  }
}
EOF

# Create variables.tf
cat > variables.tf << 'EOF'
variable "environment" {
  description = "Environment name"
  type        = string
  default     = "dev"
  
  validation {
    condition     = contains(["dev", "prod"], var.environment)
    error_message = "Environment must be dev or prod."
  }
}

variable "project_name" {
  description = "Project identifier"
  type        = string
  default     = "webapp"
}

variable "network_cidr" {
  description = "Network CIDR block"
  type        = string
  default     = "10.20.0.0/24"
}

variable "vm_specs" {
  description = "VM specifications per environment"
  type = map(object({
    web = object({
      memory    = number
      vcpu      = number
      disk_size = number
    })
    app = object({
      memory    = number
      vcpu      = number
      disk_size = number
    })
    db = object({
      memory    = number
      vcpu      = number
      disk_size = number
    })
  }))
  
  default = {
    dev = {
      web = {
        memory    = 1024
        vcpu      = 1
        disk_size = 16106127360
      }
      app = {
        memory    = 1024
        vcpu      = 1
        disk_size = 16106127360
      }
      db = {
        memory    = 1024
        vcpu      = 1
        disk_size = 16106127360
      }
    }
    prod = {
      web = {
        memory    = 2048
        vcpu      = 2
        disk_size = 26843545600
      }
      app = {
        memory    = 2048
        vcpu      = 2
        disk_size = 26843545600
      }
      db = {
        memory    = 4096
        vcpu      = 2
        disk_size = 26843545600
      }
    }
  }
}
EOF

# Create outputs.tf
cat > outputs.tf << 'EOF'
output "network_info" {
  description = "Network information"
  value = {
    name = libvirt_network.app_network.name
    id   = libvirt_network.app_network.id
  }
}

output "web_server" {
  description = "Web server information"
  value = {
    name   = libvirt_domain.web.name
    memory = libvirt_domain.web.memory
    vcpu   = libvirt_domain.web.vcpu
    id     = libvirt_domain.web.id
  }
}

output "app_server" {
  description = "Application server information"
  value = {
    name   = libvirt_domain.app.name
    memory = libvirt_domain.app.memory
    vcpu   = libvirt_domain.app.vcpu
    id     = libvirt_domain.app.id
  }
}

output "db_server" {
  description = "Database server information"
  value = {
    name   = libvirt_domain.db.name
    memory = libvirt_domain.db.memory
    vcpu   = libvirt_domain.db.vcpu
    id     = libvirt_domain.db.id
  }
}

output "environment" {
  description = "Current environment"
  value       = var.environment
}
EOF

# Create cloud-init files
cat > cloud-init-web.yaml << 'EOF'
#cloud-config
hostname: ${hostname}
fqdn: ${hostname}.local
manage_etc_hosts: true

users:
  - name: ubuntu
    sudo: ALL=(ALL) NOPASSWD:ALL
    shell: /bin/bash
    ssh_authorized_keys:
      - ssh-rsa AAAAB3NzaC1yc2EAAAADAQABAAABAQC... # Placeholder

packages:
  - nginx
  - curl

write_files:
  - path: /var/www/html/index.html
    content: |
      <!DOCTYPE html>
      <html>
      <head><title>${environment} Web Server</title></head>
      <body>
        <h1>Web Server - ${environment} Environment</h1>
        <p>Hostname: ${hostname}</p>
        <p>Environment: ${environment}</p>
      </body>
      </html>

runcmd:
  - systemctl enable nginx
  - systemctl start nginx
  - echo "Web server configured for ${environment}" > /var/log/cloud-init-complete.log
EOF

cat > cloud-init-app.yaml << 'EOF'
#cloud-config
hostname: ${hostname}
fqdn: ${hostname}.local
manage_etc_hosts: true

users:
  - name: ubuntu
    sudo: ALL=(ALL) NOPASSWD:ALL
    shell: /bin/bash

packages:
  - python3
  - python3-pip

write_files:
  - path: /opt/app/server.py
    content: |
      #!/usr/bin/env python3
      from http.server import HTTPServer, BaseHTTPRequestHandler
      import json
      
      class Handler(BaseHTTPRequestHandler):
          def do_GET(self):
              self.send_response(200)
              self.send_header('Content-type', 'application/json')
              self.end_headers()
              data = {
                  'hostname': '${hostname}',
                  'environment': '${environment}',
                  'status': 'running'
              }
              self.wfile.write(json.dumps(data).encode())
      
      HTTPServer(('0.0.0.0', 8080), Handler).serve_forever()

runcmd:
  - chmod +x /opt/app/server.py
  - nohup python3 /opt/app/server.py &
  - echo "App server configured for ${environment}" > /var/log/cloud-init-complete.log
EOF

cat > cloud-init-db.yaml << 'EOF'
#cloud-config
hostname: ${hostname}
fqdn: ${hostname}.local
manage_etc_hosts: true

users:
  - name: ubuntu
    sudo: ALL=(ALL) NOPASSWD:ALL
    shell: /bin/bash

packages:
  - sqlite3

runcmd:
  - mkdir -p /var/lib/database
  - sqlite3 /var/lib/database/app.db "CREATE TABLE users (id INTEGER PRIMARY KEY, name TEXT, email TEXT);"
  - sqlite3 /var/lib/database/app.db "INSERT INTO users VALUES (1, 'Admin', 'admin@example.com');"
  - echo "Database configured for ${environment}" > /var/log/cloud-init-complete.log
EOF

# Create README
cat > README.md << 'EOF'
