#!/bin/bash
set -euxo pipefail

# Challenge 1 Setup: Introduction to IaC & Terraform Basics
# This prepares the environment for the first challenge

echo "=== Setting up Challenge 1: Introduction to IaC & Terraform Basics ==="

# Ensure we're in the workspace directory
cd /root/terraform-workspace

# Clean up any previous work
rm -f *.tf *.txt *.tfstate* .terraform.lock.hcl
rm -rf .terraform/

# Pre-populate the example main.tf in a subdirectory for reference
mkdir -p /root/terraform-workspace/examples/challenge-01
cat > /root/terraform-workspace/examples/challenge-01/main.tf << 'EOF'
# Example Solution for Challenge 1
# This is provided as a reference - try to complete the challenge yourself first!

terraform {
  required_version = ">= 1.14"
  
  required_providers {
    local = {
      source  = "hashicorp/local"
      version = "~> 2.7"
    }
  }
}

provider "local" {}

# Resource 1: Simple greeting file
resource "local_file" "hello" {
  content  = "Hello, Terraform! This is my first infrastructure as code."
  filename = "${path.module}/hello.txt"
}

# Resource 2: Training information with heredoc
resource "local_file" "info" {
  content  = <<-EOT
    Terraform Training
    ==================
    Course: TF-101
    Topic: Introduction to IaC & Terraform Basics
    
    This file was created by Terraform!
    Timestamp: ${timestamp()}
  EOT
  filename = "${path.module}/info.txt"
}

# Resource 3: Configuration file
resource "local_file" "config" {
  content  = <<-EOT
    # Application Configuration
    app_name = "terraform-training"
    version  = "1.0.0"
    environment = "development"
    
    # Features
    enable_logging = true
    enable_metrics = true
  EOT
  filename = "${path.module}/app-config.txt"
}

# Outputs
output "hello_file_id" {
  description = "ID of the hello.txt file"
  value       = local_file.hello.id
}

output "all_files" {
  description = "List of all created files"
  value = [
    local_file.hello.filename,
    local_file.info.filename,
    local_file.config.filename
  ]
}
EOF

# Create a helpful README in the examples directory
cat > /root/terraform-workspace/examples/README.md << 'EOF'
# Example Solutions

This directory contains reference solutions for each challenge.

**Important:** Try to complete each challenge yourself before looking at the examples!

## Available Examples

- `challenge-01/` - Introduction to IaC & Terraform Basics

## How to Use

1. Complete the challenge in `/root/terraform-workspace/`
2. If you get stuck, refer to these examples
3. Learn from the examples, don't just copy them!

EOF

# Set proper permissions
chmod 644 /root/terraform-workspace/examples/challenge-01/main.tf
chmod 644 /root/terraform-workspace/examples/README.md

# Display helpful message
cat << 'EOF'

╔══════════════════════════════════════════════════════════════╗
║                                                              ║
║   Challenge 1: Introduction to IaC & Terraform Basics       ║
║                                                              ║
║   📚 What You'll Do:                                         ║
║   • Learn Infrastructure as Code fundamentals               ║
║   • Write your first Terraform configuration                ║
║   • Use the Terraform CLI workflow                          ║
║   • Create resources with the local provider                ║
║                                                              ║
║   💡 Tips:                                                   ║
║   • Read the instructions carefully                         ║
║   • Follow the steps in order                               ║
║   • Example solution available in examples/challenge-01/    ║
║   • Use 'terraform console' to test expressions             ║
║                                                              ║
║   ⏱️  Estimated Time: 1.5 hours                             ║
║                                                              ║
║   Ready? Let's begin! 🚀                                     ║
║                                                              ║
╚══════════════════════════════════════════════════════════════╝

EOF

# Verify Terraform is available
terraform version

echo "✓ Challenge 1 setup complete!"
echo "Working directory: /root/terraform-workspace"
echo "Example solution: /root/terraform-workspace/examples/challenge-01/"
echo ""

exit 0

