#!/bin/bash
set -eo pipefail

# Challenge 1 Check: Introduction to IaC & Terraform Basics
# This validates that the user completed the challenge correctly

echo "Validating Challenge 1 completion..."

# Change to workspace directory
cd /root/terraform-workspace || {
    echo "❌ Error: Workspace directory not found"
    echo "💡 Hint: Make sure you're working in /root/terraform-workspace"
    exit 1
}

# Check 1: main.tf exists
if [ ! -f "main.tf" ]; then
    echo "❌ Error: main.tf file not found"
    echo "💡 Hint: Create a main.tf file with your Terraform configuration"
    echo "📚 Review: Part 4 of the assignment for file structure"
    exit 1
fi
echo "✓ main.tf file exists"

# Check 2: Terraform block exists with required version
if ! grep -q "terraform {" main.tf; then
    echo "❌ Error: terraform block not found in main.tf"
    echo "💡 Hint: Add a terraform block with required_version and required_providers"
    echo "📚 Review: Part 3 - Provider Configuration section"
    exit 1
fi
echo "✓ terraform block found"

# Check 3: Provider configuration exists
if ! grep -q "provider \"local\"" main.tf; then
    echo "❌ Error: local provider not configured"
    echo "💡 Hint: Add 'provider \"local\" {}' to your configuration"
    echo "📚 Review: Part 3 - Provider Configuration section"
    exit 1
fi
echo "✓ local provider configured"

# Check 4: At least one resource exists
if ! grep -q "resource \"local_file\"" main.tf; then
    echo "❌ Error: No local_file resources found"
    echo "💡 Hint: Create at least one local_file resource"
    echo "📚 Review: Part 5 - Hands-On Lab, Step 2"
    exit 1
fi
echo "✓ local_file resource(s) defined"

# Check 5: Terraform has been initialized
if [ ! -d ".terraform" ]; then
    echo "❌ Error: Terraform not initialized"
    echo "💡 Hint: Run 'terraform init' to initialize your configuration"
    echo "📚 Review: Part 5 - Step 3 (Initialize Terraform)"
    exit 1
fi
echo "✓ Terraform initialized (.terraform directory exists)"

# Check 6: Lock file exists
if [ ! -f ".terraform.lock.hcl" ]; then
    echo "❌ Error: Provider lock file not found"
    echo "💡 Hint: Run 'terraform init' to create the lock file"
    echo "📚 Review: Part 5 - Step 3 (Initialize Terraform)"
    exit 1
fi
echo "✓ Provider lock file exists"

# Check 7: Terraform configuration is valid
if ! terraform validate > /dev/null 2>&1; then
    echo "❌ Error: Terraform configuration is invalid"
    echo "💡 Hint: Run 'terraform validate' to see specific errors"
    echo "📚 Common issues:"
    echo "   - Missing closing braces"
    echo "   - Typos in resource or argument names"
    echo "   - Missing required arguments"
    exit 1
fi
echo "✓ Terraform configuration is valid"

# Check 8: State file exists (user completed the workflow)
# Note: State may be empty if user ran 'terraform destroy' as instructed in Step 9
if [ ! -f "terraform.tfstate" ]; then
    echo "❌ Error: No state file found"
    echo "💡 Hint: Run 'terraform apply' at least once to create the state file"
    echo "📚 Review: Part 5 - Step 5 (Apply Changes)"
    exit 1
fi
echo "✓ State file exists (Terraform workflow completed)"

# Check 9: Verify user went through the full workflow
# We check that .terraform.lock.hcl was created, which proves init was run
if [ ! -f ".terraform.lock.hcl" ]; then
    echo "❌ Error: Lock file missing"
    echo "💡 Hint: This shouldn't happen if you followed the steps"
    exit 1
fi
echo "✓ Full Terraform workflow completed (init → plan → apply)"

# Success message
cat << 'EOF'

╔══════════════════════════════════════════════════════════════╗
║                                                              ║
║   ✅ Challenge 1 Complete!                                   ║
║                                                              ║
║   Congratulations! You've successfully:                     ║
║   • Created your first Terraform configuration              ║
║   • Initialized Terraform                                   ║
║   • Applied your configuration                              ║
║   • Created infrastructure resources                        ║
║                                                              ║
║   🎓 Key Skills Learned:                                     ║
║   • Infrastructure as Code fundamentals                     ║
║   • Terraform workflow (init, plan, apply)                  ║
║   • Resource creation with providers                        ║
║   • State management basics                                 ║
║                                                              ║
║   🚀 Ready for Challenge 2?                                  ║
║   Next up: Variables, Loops & Functions                     ║
║                                                              ║
╚══════════════════════════════════════════════════════════════╝

EOF

echo "✓ All checks passed!"
exit 0

