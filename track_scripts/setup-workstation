#!/bin/bash
set -euxo pipefail

# Track-level setup script for TF-100 Fundamentals Lab
# This runs once when the track starts

echo "=== TF-100 Terraform Fundamentals Lab Setup ==="
echo "Setting up your learning environment..."

# Update system
export DEBIAN_FRONTEND=noninteractive
echo "Updating package lists..."
apt-get update -y > /dev/null 2>&1 || { echo "Failed to update package lists"; exit 1; }

# Install prerequisites
echo "Installing prerequisites..."
apt-get install -y \
    wget \
    curl \
    unzip \
    gnupg \
    software-properties-common \
    apt-transport-https \
    ca-certificates \
    lsb-release > /dev/null 2>&1 || { echo "Failed to install prerequisites"; exit 1; }

# Install Terraform (latest stable)
echo "Installing Terraform..."
wget -O- https://apt.releases.hashicorp.com/gpg 2>/dev/null | gpg --dearmor -o /usr/share/keyrings/hashicorp-archive-keyring.gpg 2>/dev/null
echo "deb [signed-by=/usr/share/keyrings/hashicorp-archive-keyring.gpg] https://apt.releases.hashicorp.com $(lsb_release -cs) main" | tee /etc/apt/sources.list.d/hashicorp.list > /dev/null
apt-get update -y > /dev/null 2>&1 || { echo "Failed to update after adding Terraform repo"; exit 1; }
apt-get install -y terraform > /dev/null 2>&1 || { echo "Failed to install Terraform"; exit 1; }

# Verify Terraform installation
terraform version

# Install Libvirt and QEMU for nested virtualization
echo "Installing Libvirt and QEMU..."
apt-get install -y \
    qemu-kvm \
    libvirt-daemon-system \
    libvirt-clients \
    bridge-utils \
    virtinst \
    virt-manager \
    cpu-checker > /dev/null 2>&1 || { echo "Failed to install Libvirt/QEMU"; exit 1; }

# Enable and start libvirt
systemctl enable libvirtd
systemctl start libvirtd

# Verify nested virtualization support
if kvm-ok; then
    echo "✓ KVM/nested virtualization is supported"
else
    echo "⚠ Warning: KVM may not be fully supported"
fi

# Add default user to libvirt group
usermod -aG libvirt $(whoami) || true

# Install Terraform Libvirt provider dependencies
echo "Installing Libvirt provider dependencies..."
apt-get install -y \
    libvirt-dev \
    pkg-config > /dev/null 2>&1 || { echo "Failed to install Libvirt provider dependencies"; exit 1; }

# Create workspace directories for different challenges
mkdir -p /root/terraform-workspace  # Challenge 1
mkdir -p /root/terraform-lab        # Challenges 2-4
mkdir -p /root/terraform-project    # Challenge 5

# Create examples directory structure (persistent across all challenges)
mkdir -p /root/terraform-workspace/examples/challenge-01
mkdir -p /root/terraform-workspace/examples/challenge-02
mkdir -p /root/terraform-workspace/examples/challenge-03
mkdir -p /root/terraform-workspace/examples/challenge-04
mkdir -p /root/terraform-workspace/examples/challenge-05

cd /root/terraform-workspace

# Set up default libvirt network
virsh net-list --all | grep -q default || virsh net-define /usr/share/libvirt/networks/default.xml
virsh net-start default 2>/dev/null || true
virsh net-autostart default

# Set up default libvirt storage pool
mkdir -p /var/lib/libvirt/images
virsh pool-list --all | grep -q default || virsh pool-define-as default dir --target /var/lib/libvirt/images
virsh pool-start default 2>/dev/null || true
virsh pool-autostart default

# Install helpful tools
echo "Installing additional tools..."
apt-get install -y \
    vim \
    nano \
    jq \
    tree \
    git > /dev/null 2>&1 || { echo "Failed to install additional tools"; exit 1; }

# Clone the lab assets repository
echo "Cloning lab assets from GitHub..."
REPO_URL="https://github.com/Atnaszurc/tf-100-instruqt.git"
ASSETS_DIR="/root/lab-assets"

if [ ! -d "$ASSETS_DIR" ]; then
    git clone "$REPO_URL" "$ASSETS_DIR"
    echo "✓ Lab assets cloned successfully"
else
    echo "✓ Lab assets already present"
fi

# Set bash as default shell for root user
echo "Setting bash as default shell..."
chsh -s /bin/bash root

# Configure bash completion for Terraform
terraform -install-autocomplete 2>/dev/null || true

# Ensure .bashrc is sourced for interactive shells
if ! grep -q "source ~/.bashrc" /root/.bash_profile 2>/dev/null; then
    echo "source ~/.bashrc" >> /root/.bash_profile
fi

# Create welcome message
cat > /etc/motd << 'EOF'
╔══════════════════════════════════════════════════════════════╗
║                                                              ║
║   🚀 TF-100: Terraform Fundamentals Lab                     ║
║                                                              ║
║   Welcome! Your environment is ready to go.                 ║
║                                                              ║
║   📚 What's Included:                                        ║
║   • Terraform (latest stable)                               ║
║   • Libvirt/QEMU (nested virtualization enabled)            ║
║   • Code editor with syntax highlighting                    ║
║   • All example code pre-populated                          ║
║                                                              ║
║   💡 Tips:                                                   ║
║   • Use both Terminal and Code Editor tabs                  ║
║   • Read instructions carefully                             ║
║   • Experiment and learn by doing                           ║
║   • Use 'terraform console' to test expressions             ║
║                                                              ║
║   ⏱️  Time: ~8 hours | 9-hour timeout                       ║
║   🔄 Skip enabled: Restart at any challenge                 ║
║                                                              ║
║   Ready to master Terraform? Let's begin! 🎯                ║
║                                                              ║
╚══════════════════════════════════════════════════════════════╝
EOF

# Display versions
echo ""
echo "=== Environment Ready ==="
echo "Terraform version: $(terraform version -json | jq -r '.terraform_version')"
echo "Libvirt version: $(virsh version | head -n1)"
echo "QEMU version: $(qemu-system-x86_64 --version | head -n1)"
echo ""
echo "✓ Setup complete! Your learning environment is ready."
echo ""

# Set working directory
cd /root/terraform-workspace

exit 0

# Made with Bob
