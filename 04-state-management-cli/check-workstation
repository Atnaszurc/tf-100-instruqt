#!/bin/bash
set -e

# Challenge 4 Check: State Management & CLI
echo "Validating Challenge 4 completion..."

cd /root/terraform-lab

# Check 1: Configuration file exists
echo "✓ Checking for configuration file..."

if [ ! -f "main.tf" ]; then
    fail-message "main.tf not found. Create your Terraform configuration."
    exit 1
fi

# Check 2: Terraform initialized
echo "✓ Checking Terraform initialization..."

if [ ! -d ".terraform" ]; then
    fail-message "Terraform not initialized. Run 'terraform init' first."
    exit 1
fi

# Check 3: Configuration is valid
echo "✓ Validating Terraform configuration..."

if ! terraform validate > /dev/null 2>&1; then
    fail-message "Terraform configuration is invalid. Run 'terraform validate' to see errors."
    exit 1
fi

# Check 4: Infrastructure was applied
echo "✓ Checking if infrastructure was applied..."

if [ ! -f "terraform.tfstate" ]; then
    fail-message "No state file found. Run 'terraform apply' to create infrastructure."
    exit 1
fi

# Check 5: State contains resources
echo "✓ Checking state for resources..."

if ! terraform state list > /dev/null 2>&1; then
    fail-message "Cannot list state. Ensure infrastructure has been applied."
    exit 1
fi

resource_count=$(terraform state list | wc -l)
if [ "$resource_count" -lt 1 ]; then
    fail-message "No resources found in state. Apply infrastructure first."
    exit 1
fi

# Check 6: Check if backup was created (state pull practice)
echo "✓ Checking for state backup..."

if [ ! -f "backup.tfstate" ] && [ ! -f "terraform.tfstate.backup" ]; then
    fail-message "No state backup found. Practice 'terraform state pull > backup.tfstate' as instructed."
    exit 1
fi

# Check 7: Verify outputs are defined
echo "✓ Checking output definitions..."

if ! grep -q "output" main.tf; then
    fail-message "No outputs defined in main.tf. Define at least one output."
    exit 1
fi

# Check 8: Verify outputs work
echo "✓ Checking output values..."

terraform output > /dev/null 2>&1 || output_exit_code=$?
if [ "${output_exit_code:-0}" -ne 0 ]; then
    fail-message "Cannot retrieve outputs. Ensure outputs are properly defined and infrastructure is applied."
    exit 1
fi

# Check 9: Check if console works
echo "✓ Checking Terraform console..."

# Verify console is functional
console_output=$(echo "1 + 1" | terraform console 2>&1 || true)
if [ -z "$console_output" ]; then
    fail-message "Terraform console not working. Ensure infrastructure is applied."
    exit 1
fi

# All checks passed
echo ""
echo "╔════════════════════════════════════════════════════════════════╗"
echo "║                                                                ║"
echo "║                  ✅ Challenge 4 Complete! ✅                   ║"
echo "║                                                                ║"
echo "╚════════════════════════════════════════════════════════════════╝"
echo ""
echo "Excellent work! You've mastered Terraform state and CLI:"
echo ""
echo "  ✓ Created and managed infrastructure"
echo "  ✓ Inspected state with various commands"
echo "  ✓ Practiced state backup operations"
echo "  ✓ Defined and used outputs"
echo "  ✓ Used Terraform console"
echo ""
echo "Key Skills Mastered:"
echo "  • terraform state list/show/pull"
echo "  • terraform console for exploration"
echo "  • State backup and safety practices"
echo "  • Output management"
echo "  • Configuration validation"
echo ""
echo "💡 Advanced Tips:"
echo "   • Use 'terraform state mv' to rename resources"
echo "   • Use 'terraform state rm' to remove from state"
echo "   • Use 'terraform import' to add existing resources"
echo "   • Enable TF_LOG=DEBUG for troubleshooting"
echo "   • Use remote backends (HCP Terraform) for team collaboration"
echo "   • For multi-environment management, use separate backends instead of workspaces"
echo ""
echo "Next: Challenge 5 - Skills Assessment"
echo "Put all your Terraform knowledge to the test! 🎯"
echo ""

exit 0

